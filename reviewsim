    let currentRoundQuestions = [];
    let sessionData = {}; 
    let currentIndex = 0;
    let score = 0;
    const questionsPerRound = 10; 

    const area = document.getElementById('interactive-area');
    const feedbackBox = document.getElementById('feedback-box');
    const hintBox = document.getElementById('hint-box');
    const desmosBox = document.getElementById('desmos-box');
    const submitBtn = document.getElementById('submit-btn');
    const hintBtn = document.getElementById('hint-btn');
    const desmosBtn = document.getElementById('desmos-btn');
    const nextBtn = document.getElementById('next-btn');
    const progressFill = document.getElementById('progress-fill');

    function renderMath() {
        renderMathInElement(document.body, { 
            delimiters: [
                {left: "$$", right: "$$", display: true},
                {left: "\\(", right: "\\)", display: false}
            ] 
        });
    }

    function shuffle(array) { 
        let a = [...array];
        for (let i = a.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [a[i], a[j]] = [a[j], a[i]];
        }
        return a;
    }

    function startNewRound() {
        currentRoundQuestions = shuffle(questionBank).slice(0, questionsPerRound);
        sessionData = {};
        currentIndex = 0;
        score = 0;
        updateProgress();
        loadQuestion();
    }

    function updateProgress() {
        let percent = (currentIndex / questionsPerRound) * 100;
        progressFill.style.width = `${percent}%`;
    }

    function loadQuestion() {
        const q = currentRoundQuestions[currentIndex];
        document.getElementById('q-counter').innerText = `Question ${currentIndex + 1} of ${questionsPerRound}`;
        document.getElementById('q-type').innerText = `Domain: ${q.domain} | Level: ${q.difficulty}`;
        
        feedbackBox.style.display = 'none';
        hintBox.style.display = 'none';
        desmosBox.style.display = 'none';
        submitBtn.style.display = 'block';
        hintBtn.style.display = 'block';
        
        // Only show desmos button if a hint exists for this question
        desmosBtn.style.display = q.desmosHint ? 'block' : 'none';
        
        submitBtn.disabled = false;
        nextBtn.style.display = 'none';
        
        let htmlContent = "";

        if (q.type === 'msq') {
            htmlContent += `<span class="q-instruction">Multiple Choice</span><div class="question-block">${q.text}</div>`;
            q.options.forEach((opt, idx) => {
                htmlContent += `<label class="msq-option"><input type="radio" name="eoc-opt" id="rad-${idx}"> <span>${opt}</span></label>`;
            });
        } 
        else if (q.type === 'sata') {
            htmlContent += `<span class="q-instruction">Select All That Apply</span><div class="question-block">${q.text}</div>`;
            q.options.forEach((opt, idx) => {
                htmlContent += `<label class="msq-option"><input type="checkbox" id="chk-${idx}"> <span>${opt}</span></label>`;
            });
        }
        else if (q.type === 'dropdown') {
            htmlContent += `<span class="q-instruction">Inline Choice</span><div class="question-block">`;
            let parts = q.text.split('[DROP]');
            for(let i=0; i<parts.length; i++) {
                htmlContent += parts[i];
                if (i < parts.length - 1) {
                    htmlContent += `<select id="dd-${i}" class="dropdown-entry"><option value="" disabled selected>...</option>`;
                    q.options[i].forEach((optText, optIdx) => {
                        htmlContent += `<option value="${optIdx}">${optText}</option>`;
                    });
                    htmlContent += `</select>`;
                }
            }
            htmlContent += `</div>`;
        }
        else if (q.type === 'text') {
            htmlContent += `<span class="q-instruction">Equation Editor</span><div class="question-block">${q.text}</div>`;
            htmlContent += `<input type="text" id="text-answer" class="text-entry" placeholder="Type answer..." autocomplete="off">`;
        }

        area.innerHTML = htmlContent;
        setTimeout(renderMath, 20);
    }

    function showHint() {
        hintBox.innerHTML = currentRoundQuestions[currentIndex].hint;
        hintBox.style.display = 'block';
        hintBtn.style.display = 'none';
        setTimeout(renderMath, 10);
    }

    function showDesmosHint() {
        desmosBox.innerHTML = currentRoundQuestions[currentIndex].desmosHint;
        desmosBox.style.display = 'block';
        desmosBtn.style.display = 'none';
        setTimeout(renderMath, 10);
    }

    function evaluateAnswer() {
        const q = currentRoundQuestions[currentIndex];
        let correct = false;

        if (q.type === 'msq') {
            let selectedIdx = -1;
            q.options.forEach((_, i) => { if(document.getElementById(`rad-${i}`).checked) selectedIdx = i; });
            if (selectedIdx === -1) { alert("Select an answer."); return; }
            correct = q.correctIndices.includes(selectedIdx);
        } 
        else if (q.type === 'sata') {
            let userSelections = [];
            q.options.forEach((_, i) => { if(document.getElementById(`chk-${i}`).checked) userSelections.push(i); });
            if (userSelections.length === 0) { alert("Select at least one."); return; }
            correct = (userSelections.length === q.correctIndices.length) && userSelections.every(val => q.correctIndices.includes(val));
        }
        else if (q.type === 'dropdown') {
            let allAnswered = true; let allCorrect = true;
            q.options.forEach((_, i) => {
                let sel = document.getElementById(`dd-${i}`).value;
                if (sel === "") allAnswered = false;
                if (parseInt(sel) !== q.correctIndices[i]) allCorrect = false;
            });
            if (!allAnswered) { alert("Complete all menus."); return; }
            correct = allCorrect;
        }
        else if (q.type === 'text') {
            let val = document.getElementById('text-answer').value.trim().toLowerCase();
            if (val === "") { alert("Type an answer."); return; }
            correct = val === q.correctText.toLowerCase();
        }

        if (!sessionData[q.domain]) sessionData[q.domain] = { total: 0, correct: 0 };
        sessionData[q.domain].total++;
        if (correct) { sessionData[q.domain].correct++; score++; }

        showFeedback(correct, q.explanation, q.std);
    }

    function showFeedback(correct, explanation, std) {
        feedbackBox.style.display = 'block';
        feedbackBox.className = 'feedback ' + (correct ? 'correct' : 'incorrect');
        feedbackBox.innerHTML = `<strong>${correct ? "✔ Correct" : "✖ Incorrect"}</strong> (Standard: ${std})<br><br>${explanation}`;
        submitBtn.style.display = 'none';
        hintBtn.style.display = 'none';
        desmosBtn.style.display = 'none';
        nextBtn.style.display = 'block';
        setTimeout(renderMath, 10);
    }

    function nextQuestion() {
        currentIndex++;
        updateProgress();
        if (currentIndex < questionsPerRound) loadQuestion();
        else showFinal();
    }

    function showFinal() {
        let domainHTML = "";
        for (const [dom, data] of Object.entries(sessionData)) {
            let pct = Math.round((data.correct / data.total) * 100);
            let barColor = pct >= 70 ? "var(--proficient)" : (pct >= 50 ? "var(--basic)" : "var(--limited)");
            domainHTML += `
                <div class="domain-row">
                    <div style="display:flex; justify-content:space-between; margin-bottom:5px;">
                        <strong>${dom}</strong> <span>${data.correct} / ${data.total}</span>
                    </div>
                    <div class="domain-bar-bg"><div class="domain-bar-fill" style="width: ${pct}%; background-color: ${barColor};"></div></div>
                </div>`;
        }

        let tier = "", tierScore = "", color = "";
        if (score <= 4) { tier = "Limited"; tierScore = "650 - 681"; color = "var(--limited)"; }
        else if (score <= 6) { tier = "Basic"; tierScore = "682 - 699"; color = "var(--basic)"; }
        else if (score <= 8) { tier = "Proficient"; tierScore = "700 - 724"; color = "var(--proficient)"; }
        else if (score === 9) { tier = "Accelerated"; tierScore = "725 - 752"; color = "var(--accelerated)"; }
        else { tier = "Advanced"; tierScore = "753+"; color = "var(--advanced)"; }

        area.innerHTML = `
            <div style="text-align:center;">
                <p style="text-transform: uppercase; font-size: 0.9rem; color: #64748b; font-weight: 800;">Estimated EOC Level</p>
                <h2 style="font-size: 42px; margin: 0; color: ${color};">${tier}</h2>
                <p style="margin-bottom: 20px; font-size: 1.1rem; color: #64748b;">Score Range: ${tierScore}</p>
                <div class="report-card">
                    <h3 style="margin-top:0; border-bottom:1px solid #e2e8f0; padding-bottom:10px;">Performance by Reporting Category</h3>
                    ${domainHTML}
                </div>
                <br><button class="btn btn-submit" onclick="startNewRound()">Start New Practice Test</button>
            </div>`;
        submitBtn.style.display = 'none';
        hintBtn.style.display = 'none';
        desmosBtn.style.display = 'none';
        nextBtn.style.display = 'none';
        feedbackBox.style.display = 'none';
        hintBox.style.display = 'none';
        desmosBox.style.display = 'none';
    }

    window.onload = startNewRound;
</script>

</body>
</html>
