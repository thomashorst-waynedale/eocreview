<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ohio Algebra 1 EOC Simulator (with Desmos Guides)</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css">
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/contrib/auto-render.min.js"></script>

    <style>
        :root {
            --primary: #0284c7;
            --primary-hover: #0369a1;
            --bg-color: #f8fafc;
            --card-bg: #ffffff;
            --text-main: #334155;
            --border-color: #e2e8f0;
            --advanced: #8b5cf6;
            --accelerated: #10b981;
            --proficient: #3b82f6;
            --basic: #f59e0b;
            --limited: #ef4444;
            --desmos-color: #1a237e;
        }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background-color: var(--bg-color); color: var(--text-main); display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; padding: 20px; }
        .simulator-container { background-color: var(--card-bg); width: 100%; max-width: 850px; padding: 40px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border-top: 8px solid var(--primary); }
        .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid var(--border-color); padding-bottom: 15px; margin-bottom: 25px; }
        h1 { color: var(--primary); font-size: 22px; margin: 0; text-transform: uppercase; letter-spacing: 1px; }
        .target-badge { background-color: #e0f2fe; color: var(--primary-hover); padding: 6px 12px; border-radius: 20px; font-weight: bold; font-size: 14px; }
        .progress-bar { width: 100%; height: 8px; background-color: var(--border-color); border-radius: 4px; margin-bottom: 20px; overflow: hidden; }
        .progress-fill { height: 100%; background-color: var(--primary); width: 0%; transition: width 0.3s ease; }
        .meta-info { display: flex; justify-content: space-between; color: #64748b; font-weight: 600; margin-bottom: 20px; font-size: 14px; }
        .question-block { font-size: 1.25rem; line-height: 1.6; margin-bottom: 25px; font-weight: 500; }
        .q-instruction { font-size: 0.85rem; color: #64748b; font-weight: 800; text-transform: uppercase; margin-bottom: 15px; display: block; background: #f1f5f9; padding: 4px 8px; border-radius: 4px; width: fit-content; }
        .msq-option { display: flex; align-items: center; background: #f8fafc; border: 1px solid var(--border-color); padding: 14px 18px; margin-bottom: 10px; border-radius: 8px; cursor: pointer; transition: 0.2s; font-size: 1.1rem; }
        .msq-option:hover { background: #f1f5f9; border-color: #94a3b8; }
        .msq-option input { margin-right: 15px; width: 20px; height: 20px; accent-color: var(--primary); }
        .text-entry { font-size: 1.2rem; padding: 12px; border: 2px solid var(--border-color); border-radius: 8px; width: 100%; max-width: 300px; box-sizing: border-box; }
        .dropdown-entry { font-size: 1.1rem; padding: 6px; border: 2px solid var(--primary); border-radius: 6px; background: #f0f9ff; color: var(--text-main); font-weight: bold; margin: 0 4px; }
        .button-group { margin-top: 30px; display: flex; flex-wrap: wrap; gap: 10px; }
        .btn { padding: 14px 28px; font-size: 1.05rem; border-radius: 8px; cursor: pointer; font-weight: bold; border: none; transition: 0.2s; }
        .btn-submit { background: var(--primary); color: white; }
        .btn-hint { background: #dcfce7; color: #166534; }
        .btn-desmos { background: #e8eaf6; color: var(--desmos-color); border: 1px solid #c5cae9; }
        .btn-desmos:hover { background: #c5cae9; }
        .hint-box { margin-top: 20px; padding: 15px; border-radius: 8px; display: none; font-size: 1.05rem; line-height: 1.5; }
        .math-hint-style { background: #f0fdf4; border-left: 5px solid var(--accelerated); color: #166534; }
        .desmos-hint-style { background: #f8f9fa; border-left: 5px solid var(--desmos-color); color: var(--desmos-color); }
        .feedback { margin-top: 25px; padding: 20px; border-radius: 8px; display: none; line-height: 1.6; }
        .feedback.correct { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }
        .feedback.incorrect { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
        .report-card { background: #f8fafc; border: 1px solid var(--border-color); border-radius: 12px; padding: 25px; margin-top: 20px; }
        .domain-row { margin-bottom: 15px; }
        .domain-bar-bg { width: 100%; height: 10px; background: #e2e8f0; border-radius: 5px; overflow: hidden; margin-top: 5px; }
        .domain-bar-fill { height: 100%; background: var(--primary); transition: width 0.5s; }
    </style>
</head>
<body>

<div class="simulator-container">
    <div class="header">
        <h1>Ohio EOC Algebra 1 Simulator</h1>
        <div class="target-badge">Goal: Proficient (700+)</div>
    </div>
    <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
    <div class="meta-info"><span id="q-counter">Loading...</span><span id="q-type"></span></div>
    
    <div id="interactive-area"></div>
    
    <div class="button-group">
        <button id="submit-btn" class="btn btn-submit" onclick="evaluateAnswer()">Submit Answer</button>
        <button id="hint-btn" class="btn btn-hint" onclick="showHint()">💡 Math Hint</button>
        <button id="desmos-btn" class="btn btn-desmos" onclick="showDesmosHint()">📈 Desmos Guide</button>
        <button id="next-btn" class="btn btn-submit" onclick="nextQuestion()" style="display:none;">Next Question &rarr;</button>
    </div>
    
    <div id="hint-box" class="hint-box math-hint-style"></div>
    <div id="desmos-box" class="hint-box desmos-hint-style"></div>
    <div id="feedback-box" class="feedback"></div>
</div>

<script>
    const questionBank = [
        // --- DOMAIN 1: NUMBER, QUANTITIES, EQUATIONS & EXPRESSIONS ---
        { 
            domain: "Equations & Expressions", difficulty: "Easy", type: "text", std: "A-REI.3", 
            text: "Solve for \\( x \\): \\( 3x - 7 = 14 \\).", correctText: "7", 
            hint: "Add 7 to both sides, then divide by 3.", 
            desmosHint: "**Desmos EOC Trick:** Graph `y = 3x - 7` on line 1 and `y = 14` on line 2. Click the point where the two lines intersect. The x-coordinate is your answer!",
            explanation: "\\( 3x = 21 \\), so \\( x = 7 \\)." 
        },
        { 
